{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/login",
      "destination": "https://dashboard.mia-ia-system.com/welcome",
      "permanent": false
    },
    {
      "source": "/login/",
      "destination": "https://dashboard.mia-ia-system.com/welcome",
      "permanent": false
    },
    {
      "source": "/register",
      "destination": "https://dashboard.mia-ia-system.com/welcome",
      "permanent": false
    },
    {
      "source": "/register/",
      "destination": "https://dashboard.mia-ia-system.com/welcome",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/mia-fixes.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/mia-fixes.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
